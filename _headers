/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://unpkg.com https://www.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' https://unpkg.com; connect-src 'self' https://efficient-reverence-production-1b4a.up.railway.app https://www.clarity.ms; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
